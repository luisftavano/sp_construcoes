# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Firestore (opcional — se ausente, usa InMemoryRepository)
USE_FIRESTORE=false
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Asaas (pagamentos)
ASAAS_API_KEY=
ASAAS_API_URL=https://api.asaas.com/v3

# Kango AI
KANGO_API_URL=
KANGO_API_KEY=
KANGO_MOCK=true

PORT=3000
# development | production  — seed e endpoints /dev só existem quando != production
NODE_ENV=development
